# ══════════════════════════════════════════════════════
# BC Research Bot — Environment Variables
# ══════════════════════════════════════════════════════

# ── CRITICAL: Paper trade mode (must be true for research) ──
PAPER_TRADE=true
LOG_LEVEL=info,solana_memecoin_bot=debug

# ── RPC (reuse from original bot) ──
SOLANA_RPC_URL=https://solana-mainnet.core.chainstack.com/YOUR_KEY
SOLANA_WS_URL=wss://solana-mainnet.core.chainstack.com/YOUR_KEY
SOLANA_RPC_BACKUP_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Helius (for DAS/getAsset calls) ──
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Supabase (NEW project — not the original!) ──
SUPABASE_URL=https://YOUR_NEW_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_NEW_SERVICE_ROLE_KEY

# ── Wallet (paper-trade wallet — minimal SOL needed) ──
BOT_WALLET_ADDRESS=YOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY

# ── Execution (disable real TX sending) ──
USE_JITO=false
USE_HELIUS_SENDER=false
HELIUS_SENDER_URL=
HELIUS_SENDER_TIP_SOL=0

# ── Detection ──
DETECTION_METHOD=pumpfun_ws

# ── APIs (reuse from original) ──
JUPITER_API_KEY=YOUR_JUPITER_KEY
BIRDEYE_API_KEY=YOUR_BIRDEYE_KEY

# ── Optional (leave blank to disable) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OPENAI_API_KEY=
SOLANA_TRACKER_API_KEY=
X_API_BEARER_TOKEN=
LUNARCRUSH_API_KEY=

# ── Yellowstone gRPC (optional — leave ENABLE=false to skip) ──
YELLOWSTONE_GRPC_ENDPOINT=
YELLOWSTONE_GRPC_X_TOKEN=
YELLOWSTONE_GRPC_USERNAME=
YELLOWSTONE_GRPC_PASSWORD=
ENABLE_YELLOWSTONE_GRPC=false
